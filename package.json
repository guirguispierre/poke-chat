{
  "name": "poke-study-chatbot",
  "version": "1.0.0",
  "description": "Open-source React UI for a multi-session Poke study chatbot",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "relay:build": "npm --prefix poke-relay run build",
    "relay:start": "npm --prefix poke-relay run serve",
    "relay:dev": "npm --prefix poke-relay run start"
  },
  "keywords": [
    "poke",
    "chatbot",
    "react",
    "study"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guirguispierre/poke-chat.git"
  },
  "bugs": {
    "url": "https://github.com/guirguispierre/poke-chat/issues"
  },
  "homepage": "https://github.com/guirguispierre/poke-chat#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.14"
  }
}
